    <usecase>0</usecase>
    <answer fraction="100" format="moodle_auto_format"><text>chown -R www-data:www-data glpi</text><feedback format="html"><text></text></feedback></answer>
    <answer fraction="100" format="moodle_auto_format"><text>chown www-data:www-data -R glpi</text><feedback format="html"><text></text></feedback></answer>
    <answer fraction="100" format="moodle_auto_format"><text>chown -R www-data:www-data ./glpi</text><feedback format="html"><text></text></feedback></answer>
    <answer fraction="100" format="moodle_auto_format"><text>chown*-R*www-data:www-data*glpi</text><feedback format="html"><text></text></feedback></answer>
    <answer fraction="100" format="moodle_auto_format"><text>chown*www-data:www-data*-R*glpi</text><feedback format="html"><text></text></feedback></answer>
  </question>

